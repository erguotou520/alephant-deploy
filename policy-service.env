# =============================================================================
# policy-service 环境变量
# 来源: alephant-policy-service-infisical-secrets (24 vars, K8s)
# 注意: 将所有 <请替换> 替换为从 Infisical 导出的真实值
# =============================================================================

# --- 数据库 ---
POSTGRES_DATABASE_URL=postgresql://alephant:<数据库密码>@postgres:5432/alephant

# --- Redis ---
REDIS_URL=redis://default:<Redis密码>@valkey:6379/0
REDIS_DB=0

# --- 邮件 ---
MAIL_HOST=<smtp.example.com>
MAIL_PORT=587
MAIL_USERNAME=<请替换>
MAIL_PASSWORD=<请替换>
MAIL_FROM_ADDRESS=<noreply@example.com>
MAIL_FROM_NAME=Alephant

# --- Policy ---
POLICY_CONFIG_STREAM=<请替换>
POLICY_NOTIFY_CHANNEL=<请替换>
POLICY_USE_STREAM=true
POLICY_STREAM_BATCH_SIZE=100
POLICY_STREAM_BLOCK_MS=1000
POLICY_STREAM_CONSUMER_GROUP=<请替换>
POLICY_STREAM_CONSUMER_NAME=<请替换>
POLICY_BOOTSTRAP_REFRESH=true
POLICY_BOOTSTRAP_REFRESH_CONCURRENCY=10
POLICY_BOOTSTRAP_REFRESH_TIMEOUT_SEC=30
ENDPOINT_POLICY_CONFIG_STREAM=<请替换>

# --- Notification ---
NOTIFICATION_ENCRYPTION_KEY=<请替换>
NOTIFICATION_OUTBOX_NOTIFY_CHANNEL=<请替换>

# --- Watcher ---
WATCHER_ENABLED=true

# --- 日志 ---
LOG_LEVEL=info
