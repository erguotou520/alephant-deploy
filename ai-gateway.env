# =============================================================================
# ai-gateway 环境变量
# 来源: alephant-ai-gateway-infisical-secrets (27 vars, K8s)
# 注意: 将所有 <请替换> 替换为从 Infisical 导出的真实值
# =============================================================================

# --- 数据库 ---
POSTGRES_DATABASE_URL=postgresql://alephant:<数据库密码>@postgres:5432/alephant
AI_GATEWAY__DATABASE__URL=postgresql://alephant:<数据库密码>@postgres:5432/alephant

# --- Redis ---
REDIS_URL=redis://default:<Redis密码>@valkey:6379/0

# --- ClickHouse ---
CLICKHOUSE_CREDS=default:<ClickHouse密码>

# --- Qdrant (Semantic Cache) ---
AI_GATEWAY__SEMANTIC_CACHE__QDRANT__URL=http://qdrant:6333
AI_GATEWAY__SEMANTIC_CACHE__QDRANT__API_KEY=<Qdrant API Key>

# --- Cloudflare KV ---
AI_GATEWAY__CLOUDFLARE_KV__ACCOUNT_ID=<请替换>
AI_GATEWAY__CLOUDFLARE_KV__API_BASE=<请替换>
AI_GATEWAY__CLOUDFLARE_KV__API_TOKEN=<请替换>
AI_GATEWAY__CLOUDFLARE_KV__NAMESPACE_ID=<请替换>

# --- 内部服务连接 ---
AI_GATEWAY__POLICY__GRPC_ENDPOINT=policy-service:9090
AI_GATEWAY__X402__PAYMENT_GRPC_ENDPOINT=ledge-service:9090
AI_GATEWAY__X402__UPSTREAM_AUTH_KEY=<请替换>
AI_GATEWAY__ALEPHANT__LOG_COLLECTOR_URL=http://logs-collector:8585
AI_GATEWAY__REQUEST_LOG__TRANSPORT=log_collector

# --- S3 ---
S3_ENDPOINT=<请替换>
S3_REGION=<请替换>
S3_BUCKET_NAME=<请替换>
S3_ACCESS_KEY=<请替换>
S3_SECRET_KEY=<请替换>

# --- Security ---
JWT_SECRET=<请替换>
ENCRYPTION_KEY=<请替换>
MASTER_KEY_ENCRYPTION_KEY=<请替换>
PAYMENT_SERVICE_KEY=<请替换>
LOGS_COLLECTOR_X402_HTTP_AUTH_TOKEN=<请替换>

# --- Analytics ---
ANALYTICS_RMT_MAX_RANGE_HOURS=72
