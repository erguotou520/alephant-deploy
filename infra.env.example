# =============================================================================
# 基础设施凭证 (Infrastructure Credentials)
# 供 postgres / clickhouse / valkey / qdrant 等基础设施服务使用
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=alephant
POSTGRES_USER=alephant
POSTGRES_PASSWORD=<请替换>

# --- ClickHouse ---
CLICKHOUSE_DB=alephant
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=<请替换>

# --- Valkey (Redis) ---
VALKEY_PASSWORD=<请替换>

# --- Qdrant ---
QDRANT_API_KEY=<请替换>
