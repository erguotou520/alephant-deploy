# =============================================================================
# logs-collector 环境变量
# 来源: alephant-logs-collector-infisical-secrets (12 vars, K8s)
# 注意: 将所有 <请替换> 替换为从 Infisical 导出的真实值
# =============================================================================

# --- 数据库 ---
POSTGRES_DATABASE_URL=postgresql://alephant:<数据库密码>@postgres:5432/alephant

# --- Redis ---
REDIS_URL=redis://default:<Redis密码>@valkey:6379/0

# --- ClickHouse ---
CLICKHOUSE_CREDS=default:<ClickHouse密码>

# --- S3 ---
S3_ENDPOINT=<请替换>
S3_REGION=<请替换>
S3_BUCKET_NAME=<请替换>
S3_ACCESS_KEY=<请替换>
S3_SECRET_KEY=<请替换>

# --- Security ---
JWT_SECRET=<请替换>
ENCRYPTION_KEY=<请替换>
LOGS_COLLECTOR_X402_HTTP_AUTH_TOKEN=<请替换>

# --- Analytics ---
ANALYTICS_RMT_MAX_RANGE_HOURS=72
